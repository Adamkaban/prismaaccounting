---
// No props - fully self-contained interactive island
---

<div class="py-20 md:py-32">
  <div class="container-page">

    <!-- Input -->
    <div class="max-w-2xl mb-12">
      <div>
        <div class="flex items-center justify-between mb-3">
          <label for="gross-salary-slider" class="text-sm font-medium">
            Gross annual salary
          </label>
          <input
            type="number"
            id="gross-salary-input"
            min="1000"
            max="500000"
            step="1000"
            value="80000"
            class="w-32 text-sm font-mono text-right border border-[var(--color-line)] rounded-lg px-3 py-1.5 bg-[var(--color-bg-elev)] focus:outline-none focus:border-[var(--color-accent)]"
          />
        </div>
        <input
          type="range"
          id="gross-salary-slider"
          min="30000"
          max="300000"
          step="5000"
          value="80000"
          class="w-full cursor-pointer"
          style="accent-color: var(--color-accent)"
        />
        <div class="flex justify-between mt-1.5 text-xs text-[var(--color-ink-muted)] font-mono">
          <span>$30K</span><span>$300K</span>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div class="grid gap-6 md:grid-cols-2 max-w-2xl">

      <!-- Net take-home card -->
      <div class="rounded-2xl border bg-[var(--color-bg-elev)] p-8" style="border-color: var(--color-accent)">
        <div class="text-xs font-medium uppercase tracking-widest text-[var(--color-ink-muted)] mb-4">Net take-home</div>
        <div id="net-annual" class="text-4xl font-medium font-mono tracking-tight">--</div>
        <div class="mt-2 text-sm text-[var(--color-ink-muted)]">
          <span id="net-monthly" class="font-mono">--</span> / month &nbsp;&middot;&nbsp;
          <span id="net-biweekly" class="font-mono">--</span> / biweek
        </div>
        <div class="mt-4 pt-4 border-t border-[var(--color-line)]">
          <div class="flex justify-between text-sm">
            <span class="text-[var(--color-ink-muted)]">Effective rate</span>
            <span id="effective-rate" class="font-mono font-medium">--</span>
          </div>
        </div>
      </div>

      <!-- Deductions breakdown card -->
      <div class="rounded-2xl border bg-[var(--color-bg-elev)] p-8" style="border-color: var(--color-line)">
        <div class="text-xs font-medium uppercase tracking-widest text-[var(--color-ink-muted)] mb-6">Annual deductions</div>
        <dl class="space-y-3">
          <div class="flex justify-between text-sm">
            <dt class="text-[var(--color-ink-muted)]">Federal income tax</dt>
            <dd id="federal-tax" class="font-mono">--</dd>
          </div>
          <div class="flex justify-between text-sm">
            <dt class="text-[var(--color-ink-muted)]">Ontario income tax</dt>
            <dd id="ontario-tax" class="font-mono">--</dd>
          </div>
          <div class="flex justify-between text-sm">
            <dt class="text-[var(--color-ink-muted)]">CPP contributions</dt>
            <dd id="cpp-amount" class="font-mono">--</dd>
          </div>
          <div class="flex justify-between text-sm">
            <dt class="text-[var(--color-ink-muted)]">EI premiums</dt>
            <dd id="ei-amount" class="font-mono">--</dd>
          </div>
          <div class="flex justify-between text-sm font-medium pt-3" style="border-top: 1px solid var(--color-line)">
            <dt>Total deductions</dt>
            <dd id="total-deductions" class="font-mono">--</dd>
          </div>
        </dl>
      </div>

    </div>

    <!-- Disclaimer -->
    <p class="mt-8 text-sm text-[var(--color-ink-muted)] max-w-2xl leading-relaxed">
      Estimates use 2026 federal and Ontario tax rates. Assumes Ontario resident, single income source, no additional credits or deductions beyond the basic personal amount. CPP and EI at employee rates only. Not tax advice.
    </p>

  </div>
</div>

<script>
  import {
    applyBrackets,
    ontarioSurtax,
    calculateCPP,
    calculateEI,
    BPA_2026,
    FEDERAL_BRACKETS_2026,
    ONTARIO_BRACKETS_2026,
  } from '~/lib/taxCalc2026';

  const cad = new Intl.NumberFormat('en-CA', {
    style: 'currency',
    currency: 'CAD',
    maximumFractionDigits: 0,
  });
  const fmt = (n: number) => cad.format(Math.round(n));
  const fmtPct = (n: number) => `${(n * 100).toFixed(1)}%`;

  function el<T extends HTMLElement = HTMLElement>(id: string): T {
    return document.getElementById(id) as T;
  }

  function calcNetPay(gross: number) {
    const cpp = calculateCPP(gross);
    const ei = calculateEI(gross);

    const fedBPA = BPA_2026.federal * 0.15;
    const federalBasic = applyBrackets(gross, FEDERAL_BRACKETS_2026);
    const federalTax = Math.max(
      federalBasic - fedBPA - cpp.employee * 0.15 - ei.employee * 0.15,
      0,
    );

    const onBPA = BPA_2026.ontario * 0.0505;
    const ontarioBasic = applyBrackets(gross, ONTARIO_BRACKETS_2026);
    const ontarioTax = Math.max(
      ontarioBasic + ontarioSurtax(ontarioBasic) - onBPA - cpp.employee * 0.0505 - ei.employee * 0.0505,
      0,
    );

    const totalTax = federalTax + ontarioTax;
    const totalDeductions = totalTax + cpp.employee + ei.employee;

    return {
      federalTax,
      ontarioTax,
      cpp: cpp.employee,
      ei: ei.employee,
      totalTax,
      totalDeductions,
      netPay: gross - totalDeductions,
      effectiveRate: gross > 0 ? totalDeductions / gross : 0,
    };
  }

  const slider = el<HTMLInputElement>('gross-salary-slider');
  const numberInput = el<HTMLInputElement>('gross-salary-input');

  function update(gross: number): void {
    const r = calcNetPay(gross);
    el('net-annual').textContent = fmt(r.netPay);
    el('net-monthly').textContent = fmt(r.netPay / 12);
    el('net-biweekly').textContent = fmt(r.netPay / 26);
    el('effective-rate').textContent = fmtPct(r.effectiveRate);
    el('federal-tax').textContent = fmt(r.federalTax);
    el('ontario-tax').textContent = fmt(r.ontarioTax);
    el('cpp-amount').textContent = fmt(r.cpp);
    el('ei-amount').textContent = fmt(r.ei);
    el('total-deductions').textContent = fmt(r.totalDeductions);
  }

  slider.addEventListener('input', () => {
    const v = Number(slider.value);
    numberInput.value = String(v);
    update(v);
  });

  numberInput.addEventListener('input', () => {
    const v = Math.min(Math.max(Number(numberInput.value) || 0, 1000), 500000);
    slider.value = String(Math.min(Math.max(v, 30000), 300000));
    update(v);
  });

  update(Number(slider.value));
</script>
