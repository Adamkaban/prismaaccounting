---
import { SITE } from '~/site.config';

interface BreadcrumbItem {
  name: string;
  href: string;
}

interface ServiceMeta {
  name: string;
  description: string;
  serviceType: string;
}

interface FAQItem {
  q: string;
  a: string;
}

interface ArticleMeta {
  headline: string;
  description: string;
  datePublished: string;
  dateModified?: string;
  author?: string;
  image?: string;
  url: string;
}

interface Props {
  variant?: 'home' | 'page' | 'service' | 'article';
  breadcrumbs?: BreadcrumbItem[];
  service?: ServiceMeta;
  faqItems?: FAQItem[];
  article?: ArticleMeta;
}

const { variant = 'page', breadcrumbs, service, faqItems, article } = Astro.props;

const orgUrl = SITE.url;

const organization = {
  '@type': 'AccountingService',
  '@id': `${orgUrl}/#organization`,
  name: SITE.name,
  legalName: SITE.legalName,
  url: orgUrl,
  image: `${orgUrl}/og-default.png`,
  email: SITE.contact.email,
  priceRange: 'CAD $99+',
  areaServed: [
    { '@type': 'City', name: 'Toronto' },
    { '@type': 'AdministrativeArea', name: 'Ontario' },
  ],
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.streetAddress,
    addressLocality: SITE.address.locality,
    addressRegion: SITE.address.region,
    postalCode: SITE.address.postalCode,
    addressCountry: SITE.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.address.lat,
    longitude: SITE.address.lng,
  },
  knowsAbout: [
    'Personal income tax',
    'Corporate income tax',
    'HST',
    'Payroll',
    'Bookkeeping',
    'Incorporation',
    'Canada Revenue Agency',
  ],
};

const website = {
  '@type': 'WebSite',
  '@id': `${orgUrl}/#website`,
  url: orgUrl,
  name: SITE.name,
  inLanguage: 'en-CA',
  publisher: { '@id': `${orgUrl}/#organization` },
};

// Exclude fragment-only hrefs — "/#services" is an anchor on the homepage,
// not a standalone page. Google Structured Data validation rejects fragment items.
const schemaReadyBreadcrumbs = breadcrumbs?.filter((b) => {
  const url = new URL(b.href, orgUrl);
  return !url.hash || url.pathname !== '/';
}) ?? null;

const breadcrumb = schemaReadyBreadcrumbs && schemaReadyBreadcrumbs.length > 0
  ? {
      '@type': 'BreadcrumbList',
      itemListElement: schemaReadyBreadcrumbs.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
        item: new URL(b.href, orgUrl).toString(),
      })),
    }
  : null;

const serviceNode = service
  ? {
      '@type': 'Service',
      name: service.name,
      description: service.description,
      serviceType: service.serviceType,
      provider: { '@id': `${orgUrl}/#organization` },
      areaServed: { '@type': 'City', name: 'Toronto' },
    }
  : null;

const faqPage = faqItems && faqItems.length > 0
  ? {
      '@type': 'FAQPage',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.a,
        },
      })),
    }
  : null;

const articleNode = article
  ? {
      '@type': 'Article',
      headline: article.headline,
      description: article.description,
      url: new URL(article.url, orgUrl).toString(),
      datePublished: article.datePublished,
      ...(article.dateModified ? { dateModified: article.dateModified } : {}),
      ...(article.image ? { image: new URL(article.image, orgUrl).toString() } : {}),
      author: {
        '@type': 'Organization',
        name: article.author ?? SITE.name,
        url: orgUrl,
      },
      publisher: { '@id': `${orgUrl}/#organization` },
      inLanguage: 'en-CA',
    }
  : null;

const graph: unknown[] = [organization];
if (variant === 'home') graph.push(website);
if (breadcrumb) graph.push(breadcrumb);
if (serviceNode) graph.push(serviceNode);
if (faqPage) graph.push(faqPage);
if (articleNode) graph.push(articleNode);

const jsonLd = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph });
---

<script type="application/ld+json" set:html={jsonLd} is:inline />
