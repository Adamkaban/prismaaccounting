---
import Section from '~/components/ui/Section.astro';
import Reveal from '~/components/motion/Reveal.astro';

interface Step {
  n: string;
  title: string;
  body: string;
}

interface Props {
  heading: string;
  intro: string;
  steps: Step[];
}

const { heading, intro, steps } = Astro.props;
---

<Section id="process" divider>
  <div class="max-w-3xl">
    <h2 class="text-4xl md:text-5xl font-medium tracking-tight leading-[1.1] text-balance">
      {heading}
    </h2>
    <p class="mt-5 max-w-[58ch] text-lg leading-relaxed text-[var(--color-ink-muted)]">
      {intro}
    </p>
  </div>

  <Reveal as="ol" class="mt-14 grid grid-cols-1 md:grid-cols-4 gap-0 border-t border-[var(--color-line)]">
    {
      steps.map((s, i) => (
        <li
          class={`relative py-10 md:py-12 ${i > 0 ? 'md:border-l border-t md:border-t-0' : ''} border-[var(--color-line)] md:pl-8 md:pr-6`}
        >
          <span class="font-mono text-sm text-[var(--color-ink-muted)] tracking-tight">{s.n}</span>
          <h3 class="mt-3 text-lg md:text-xl font-medium tracking-tight">{s.title}</h3>
          <p class="mt-3 text-[var(--color-ink-muted)] leading-relaxed text-sm">{s.body}</p>
        </li>
      ))
    }
  </Reveal>
</Section>
