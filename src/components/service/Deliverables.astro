---
import Section from '~/components/ui/Section.astro';
import Reveal from '~/components/motion/Reveal.astro';

interface DeliverableItem {
  title: string;
  body: string;
}

interface Props {
  heading: string;
  intro: string;
  items: DeliverableItem[];
}

const { heading, intro, items } = Astro.props;
---

<Section id="deliverables" divider>
  <div class="max-w-3xl">
    <h2 class="text-4xl md:text-5xl font-medium tracking-tight leading-[1.1] text-balance">
      {heading}
    </h2>
    <p class="mt-5 max-w-[58ch] text-lg leading-relaxed text-[var(--color-ink-muted)]">
      {intro}
    </p>
  </div>

  <Reveal as="ul" class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6">
    {
      items.map((item) => (
        <li class="rounded-2xl bg-[var(--color-bg-elev)] border border-[var(--color-line)] p-7 md:p-8">
          <h3 class="text-xl md:text-2xl font-medium tracking-tight">{item.title}</h3>
          <p class="mt-3 text-[var(--color-ink-muted)] leading-relaxed">{item.body}</p>
        </li>
      ))
    }
  </Reveal>
</Section>
