---
import { NAV, SITE } from '~/site.config';
import Button from '~/components/ui/Button.astro';
import LogoMark from '~/components/ui/LogoMark.astro';
---

<header
  class="sticky top-0 z-50 backdrop-blur-md bg-[color-mix(in_oklab,var(--color-bg)_88%,transparent)] border-b border-transparent data-[scrolled=true]:border-[var(--color-line)] transition-colors"
  data-site-header
>
  <div class="container-page flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex items-center gap-2.5 group" aria-label={`${SITE.name} home`}>
      <LogoMark size={32} />
      <span class="font-medium tracking-tight text-[var(--color-ink)]">Prisma Financial</span>
    </a>

    <nav class="hidden md:flex items-center gap-8" aria-label="Primary">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class="text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-ink)] transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:block">
      <Button href={`/${SITE.cta.anchor}`} size="md">{SITE.cta.primary}</Button>
    </div>

    <button
      type="button"
      class="md:hidden inline-flex items-center justify-center h-12 w-12 rounded-full border border-[var(--color-ink)]/15"
      aria-label="Open menu"
      aria-expanded="false"
      data-mobile-toggle
    >
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <div
    class="md:hidden hidden border-t border-[var(--color-line)] bg-[var(--color-bg)]"
    data-mobile-menu
  >
    <nav class="container-page py-6 flex flex-col gap-4" aria-label="Mobile">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class="text-base text-[var(--color-ink)] py-2 border-b border-[var(--color-line)]"
          >
            {item.label}
          </a>
        ))
      }
      <Button href={`/${SITE.cta.anchor}`} class="mt-2 w-full">{SITE.cta.primary}</Button>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-site-header]');
  if (header) {
    const onScroll = () => {
      header.dataset.scrolled = window.scrollY > 12 ? 'true' : 'false';
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  const toggle = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
</script>
