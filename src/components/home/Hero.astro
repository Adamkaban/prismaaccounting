---
import Button from '~/components/ui/Button.astro';
import Eyebrow from '~/components/ui/Eyebrow.astro';
import { SITE } from '~/site.config';
---

<section class="relative overflow-hidden pt-20 md:pt-24 pb-16 md:pb-24 min-h-[100dvh] flex items-center">
  <div class="container-page w-full">
    <div class="max-w-4xl">
      <Eyebrow class="mb-6">Toronto, Ontario</Eyebrow>

      <h1
        class="text-balance text-5xl md:text-7xl font-medium tracking-tight leading-[1.05] text-[var(--color-ink)]"
      >
        Tax and books, done right.
        <span class="block text-[var(--color-ink-muted)]">By Toronto accountants.</span>
      </h1>

      <p
        class="mt-8 max-w-[58ch] text-lg md:text-xl leading-relaxed text-[var(--color-ink-muted)]"
      >
        Personal tax, corporate tax, HST, payroll, and bookkeeping for small businesses and self-employed across the GTA.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        <Button href={SITE.cta.anchor} size="lg">{SITE.cta.primary}</Button>
        <Button href="#services" variant="secondary" size="lg">See services</Button>
      </div>
    </div>
  </div>

  <div
    aria-hidden="true"
    class="pointer-events-none absolute right-0 bottom-0 hidden md:block w-1/3 h-1/2 bg-[var(--color-bg-elev)] opacity-50 rounded-tl-[64px] border-t border-l border-[var(--color-line)]"
  ></div>
</section>
