---
import Section from '~/components/ui/Section.astro';
import Reveal from '~/components/motion/Reveal.astro';
import { SERVICES } from '~/site.config';
---

<Section id="services">
  <div class="max-w-3xl">
    <h2 class="text-4xl md:text-5xl font-medium tracking-tight leading-[1.1] text-balance">
      Six services. One file at a time.
    </h2>
    <p class="mt-5 max-w-[58ch] text-lg leading-relaxed text-[var(--color-ink-muted)]">
      Built for sole proprietors, incorporated owners, and growing teams that need CRA-ready filings without the big-firm overhead.
    </p>
  </div>

  <Reveal
    as="ul"
    class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6"
  >
    {
      SERVICES.map((svc) => (
        <li>
          <a
            href={svc.href}
            aria-disabled={!svc.available}
            class={`group block h-full rounded-2xl bg-[var(--color-bg-elev)] border border-[var(--color-line)] p-7 md:p-8 transition hover:-translate-y-0.5 hover:border-[var(--color-ink)]/20 ${!svc.available ? 'pointer-events-none opacity-70' : ''}`}
            tabindex={svc.available ? 0 : -1}
          >
            <div class="flex items-start justify-between gap-3">
              <h3 class="text-xl md:text-2xl font-medium tracking-tight">
                {svc.title}
              </h3>
              {svc.available ? (
                <svg
                  class="mt-1 transition-transform group-hover:translate-x-1"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  aria-hidden="true"
                >
                  <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              ) : (
                <span class="text-xs uppercase tracking-[0.14em] text-[var(--color-ink-muted)] font-medium">
                  Soon
                </span>
              )}
            </div>
            <p class="mt-3 text-[var(--color-ink-muted)] leading-relaxed">
              {svc.oneLiner}
            </p>
          </a>
        </li>
      ))
    }
  </Reveal>
</Section>
