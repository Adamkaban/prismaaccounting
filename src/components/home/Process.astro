---
import Section from '~/components/ui/Section.astro';
import Reveal from '~/components/motion/Reveal.astro';

const steps = [
  {
    n: '01',
    title: 'Tell us about your situation',
    body: 'Send slips, prior returns, or a quick note about your business. Five minutes through the quote form.',
  },
  {
    n: '02',
    title: 'We review and price',
    body: 'Within one business day we send a fixed CAD price, the documents we need, and a timeline.',
  },
  {
    n: '03',
    title: 'We file and follow up',
    body: 'You sign, we file with CRA, you get a copy. We handle reviews or follow-up notices at no extra charge.',
  },
];
---

<Section id="process" bg="elev" divider>
  <div class="max-w-3xl">
    <h2 class="text-4xl md:text-5xl font-medium tracking-tight leading-[1.1] text-balance">
      How it works
    </h2>
    <p class="mt-5 max-w-[58ch] text-lg leading-relaxed text-[var(--color-ink-muted)]">
      A small enough firm to pick up the phone. Predictable enough to scale with you.
    </p>
  </div>

  <Reveal as="ol" class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-0 border-t border-[var(--color-line)]">
    {
      steps.map((s, i) => (
        <li
          class={`relative py-10 md:py-12 ${i > 0 ? 'md:border-l' : ''} border-[var(--color-line)] md:pl-10 md:pr-6 ${i > 0 ? 'border-t md:border-t-0' : ''}`}
        >
          <span class="font-mono text-sm text-[var(--color-ink-muted)] tracking-tight">{s.n}</span>
          <h3 class="mt-3 text-xl md:text-2xl font-medium tracking-tight">{s.title}</h3>
          <p class="mt-3 text-[var(--color-ink-muted)] leading-relaxed">{s.body}</p>
        </li>
      ))
    }
  </Reveal>
</Section>
