---
import Section from '~/components/ui/Section.astro';

interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  id?: string;
  heading?: string;
  intro?: string;
  items?: FAQItem[];
}

const defaultItems: FAQItem[] = [
  {
    q: 'Do I need an accountant if I use TurboTax?',
    a: 'For a simple T1 with one T4 slip, software is fine. Once you add self-employment income, rental income, capital gains, or multiple years to catch up on, the cost of a mistake usually outweighs the cost of a CPA.',
  },
  {
    q: 'How long does a personal T1 return take?',
    a: 'Most straightforward returns are filed within three business days of receiving all slips. Complex returns with self-employment or rental income take five to seven business days.',
  },
  {
    q: 'Do you serve clients outside Toronto?',
    a: 'Yes. Our entire intake, signature, and filing process is remote. We work with clients across Ontario and other Canadian provinces.',
  },
  {
    q: 'How do you price your work?',
    a: 'Flat fees in CAD, quoted before any work starts. No hourly billing surprises. Pricing is on each service page.',
  },
  {
    q: 'Do you handle CRA reviews and audits?',
    a: 'Yes. If CRA asks for documentation on a return we filed, we respond on your behalf. Routine reviews are included in the original fee.',
  },
  {
    q: "Can you help if I'm behind on multiple years?",
    a: 'Yes. We file multi-year catch-ups regularly, including under the CRA Voluntary Disclosures Program when relief from penalties is available.',
  },
  {
    q: 'Do I need to come in person?',
    a: 'No. Everything is signed electronically and filed online. We are happy to meet in person in Toronto when it helps.',
  },
  {
    q: 'What records do I need to provide?',
    a: 'It depends on the service. After the initial quote we send a short checklist tailored to your situation so there is no guesswork.',
  },
];

const {
  id = 'faq',
  heading = 'Common questions',
  intro = 'Short answers to what most people ask before reaching out.',
  items = defaultItems,
} = Astro.props;
---

<Section id={id} divider>
  <div class="grid gap-12 md:grid-cols-12">
    <div class="md:col-span-4">
      <h2 class="text-4xl md:text-5xl font-medium tracking-tight leading-[1.1] text-balance">
        {heading}
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-[var(--color-ink-muted)] max-w-sm">
        {intro}
      </p>
    </div>

    <ul class="md:col-span-8 divide-y divide-[var(--color-line)] border-t border-b border-[var(--color-line)]">
      {
        items.map((item) => (
          <li>
            <details class="group py-6">
              <summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
                <h3 class="text-lg md:text-xl font-medium tracking-tight">{item.q}</h3>
                <span
                  class="mt-1 inline-flex h-7 w-7 items-center justify-center rounded-full border border-[var(--color-line)] text-[var(--color-ink-muted)] transition group-open:bg-[var(--color-ink)] group-open:text-[var(--color-bg-elev)] group-open:border-[var(--color-ink)] shrink-0"
                  aria-hidden="true"
                >
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path class="group-open:hidden" d="M12 5v14M5 12h14" stroke-linecap="round" />
                    <path class="hidden group-open:block" d="M5 12h14" stroke-linecap="round" />
                  </svg>
                </span>
              </summary>
              <div class="mt-3 pr-12 text-[var(--color-ink-muted)] leading-relaxed">
                {item.a}
              </div>
            </details>
          </li>
        ))
      }
    </ul>
  </div>
</Section>
