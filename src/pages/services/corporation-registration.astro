---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ServiceHero from '~/components/service/ServiceHero.astro';
import Deliverables from '~/components/service/Deliverables.astro';
import Pricing from '~/components/service/Pricing.astro';
import ServiceProcess from '~/components/service/ServiceProcess.astro';
import FAQ from '~/components/home/FAQ.astro';
import Section from '~/components/ui/Section.astro';
import TallyEmbed from '~/components/forms/TallyEmbed.astro';
import { SITE } from '~/site.config';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services/' },
  { name: 'Incorporation', href: '/services/corporation-registration/' },
];

const deliverables = [
  {
    title: 'Federal or Ontario incorporation',
    body: 'We file with Corporations Canada for a federal charter or with the Ontario Business Registry for a provincial corporation. We explain the trade-offs before you choose.',
  },
  {
    title: 'Articles of incorporation',
    body: 'Articles drafted and filed: share structure, restrictions, directors, and registered office. We set up a clean share structure for tax efficiency from day one.',
  },
  {
    title: 'Corporate minute book',
    body: 'Initial organizational resolutions, director and officer appointments, share issuance, and the first year of minutes. Delivered digitally in a structured PDF.',
  },
  {
    title: 'CRA business accounts',
    body: 'Business number, corporate income tax, HST, and payroll accounts registered with CRA after incorporation. You start operating with everything already in place.',
  },
];

const pricingTiers = [
  {
    name: 'Ontario corp',
    price: '$699',
    unit: 'all-in',
    blurb: 'Provincial incorporation for Ontario businesses. Government filing fees included.',
    features: [
      'Ontario Business Registry filing',
      'Articles of incorporation',
      'Digital minute book',
      'CRA account registrations',
    ],
  },
  {
    name: 'Federal corp',
    price: '$849',
    unit: 'all-in',
    blurb: 'Federal charter for businesses operating across provinces. Government filing fees included.',
    featured: true,
    features: [
      'Corporations Canada filing',
      'Articles of incorporation',
      'Digital minute book',
      'CRA account registrations',
    ],
  },
  {
    name: 'Corp + first T2',
    price: '$1,899',
    unit: 'bundle',
    blurb: 'Incorporation plus your first year\'s corporate tax return, all in.',
    features: [
      'Federal or Ontario incorporation',
      'Full minute book',
      'CRA account registrations',
      'First-year T2 return included',
    ],
  },
];

const processSteps = [
  {
    n: '01',
    title: 'Name and structure',
    body: 'We discuss your business activities, number of owners, share classes needed, and whether federal or provincial registration fits better. NUANS name search included.',
  },
  {
    n: '02',
    title: 'Articles drafted',
    body: 'Articles of incorporation prepared with a tax-efficient share structure. You review and confirm before we file anything.',
  },
  {
    n: '03',
    title: 'Filed and confirmed',
    body: 'Articles submitted to the appropriate registry. Federal turnaround is typically one to three business days. Ontario is usually same day through the Business Registry.',
  },
  {
    n: '04',
    title: 'Books and CRA setup',
    body: 'Certificate of incorporation received, minute book organized, and CRA accounts registered. You receive the complete incorporation package digitally.',
  },
];

const faqItems = [
  {
    q: 'Federal vs. Ontario corporation - which should I choose?',
    a: 'A federal corporation gives you name protection across all provinces and makes expansion easier if you ever operate outside Ontario. An Ontario corporation is slightly cheaper to incorporate and maintain, and is sufficient if you plan to operate only in Ontario. We walk through the practical differences for your situation before you decide.',
  },
  {
    q: 'What is a NUANS name search?',
    a: 'NUANS is the federal name registry search that confirms your proposed corporate name is not already in use. It is mandatory for federal incorporations and recommended for Ontario ones. We run the NUANS search as part of your engagement.',
  },
  {
    q: 'Why does share structure matter?',
    a: 'A properly designed share structure lets you split income between family members, create a holding company layer, and issue future equity to partners or employees. Setting it up correctly at incorporation costs nothing extra and avoids expensive reorganizations later.',
  },
  {
    q: 'Do I need a corporate lawyer?',
    a: 'Not for straightforward incorporations. We prepare and file all required documents. If you have complex ownership arrangements, partnership agreements, or shareholder agreements, we refer you to a corporate lawyer and coordinate the accounting side.',
  },
  {
    q: 'When does my corporation need to file its first T2?',
    a: 'The first T2 is due six months after your corporation\'s first fiscal year-end. You choose the year-end at incorporation - we advise on the best date for your cash flow and tax planning.',
  },
  {
    q: 'What are the ongoing annual maintenance requirements?',
    a: 'Federal corporations file an annual return with Corporations Canada each year. Ontario corporations file with the Ontario Business Registry. Both also require CRA corporate tax returns and, if registered, HST and payroll filings. We can handle all of this as part of an ongoing engagement.',
  },
];
---

<BaseLayout
  title="Register Corporation Ontario | Prisma Financial"
  description="Federal or Ontario corporation registration for Toronto small businesses. Articles drafted, minute book organized, CRA accounts opened. One fixed CAD price."
  path="/services/corporation-registration/"
  schemaVariant="service"
  breadcrumbs={breadcrumbs}
  faqItems={faqItems}
  service={{
    name: 'Corporation Registration',
    description:
      'Federal and Ontario corporation incorporation, articles of incorporation, minute book preparation, and CRA business account registration for Toronto businesses.',
    serviceType: 'Business incorporation',
  }}
>
  <ServiceHero
    eyebrow="Incorporation"
    title="Register a Corporation in Ontario"
    subtitle="Federal or Ontario incorporation, articles drafted, minute book organized, and CRA accounts registered. One fixed CAD price, everything included."
    breadcrumbs={breadcrumbs}
  />

  <Deliverables
    heading="What you get on day one"
    intro="Every incorporation engagement covers all four items. Nothing is quoted separately, nothing is left for you to figure out."
    items={deliverables}
  />

  <Pricing
    heading="All-in pricing"
    intro="Government fees included. No per-hour billing, no module pricing."
    tiers={pricingTiers}
    footnote="Prices in CAD plus HST. Government incorporation fees included. NUANS name search included. Shareholder agreements quoted separately."
  />

  <ServiceProcess
    heading="How incorporation works"
    intro="Most Ontario incorporations complete within 24 hours. Federal incorporations take one to three business days."
    steps={processSteps}
  />

  <Section id="tool-callout" divider>
    <p class="text-[var(--color-ink-muted)] text-lg leading-relaxed max-w-[60ch]">
      Once incorporated, the salary vs dividends decision matters.
      <a href="/tools/salary-vs-dividend/" class="text-[var(--color-accent)] underline underline-offset-4 hover:text-[var(--color-accent-hi)] transition-colors font-medium">
        Use our free 2026 Salary vs Dividend Calculator
      </a>
      to see the after-tax difference before your first payroll.
    </p>
  </Section>

  <FAQ
    id="faq"
    heading="Incorporation questions"
    intro="What sole proprietors and new business owners ask us most about incorporating."
    items={faqItems}
  />

  <Section id="quote" bg="elev" divider>
    <div class="grid gap-10 md:grid-cols-12 items-start">
      <div class="md:col-span-5">
        <h2 class="text-4xl md:text-5xl font-medium tracking-tight leading-[1.1] text-balance">
          Get a free quote
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-[var(--color-ink-muted)] max-w-sm">
          Tell us your proposed business name, number of shareholders, and whether you need federal or provincial. Price confirmed same day.
        </p>
        <p class="mt-6 text-sm text-[var(--color-ink-muted)]">
          Prefer email? Write to <a href={`mailto:${SITE.contact.email}`} class="text-[var(--color-ink)] underline underline-offset-4 hover:text-[var(--color-accent)] transition-colors">{SITE.contact.email}</a>.
        </p>
      </div>
      <div class="md:col-span-7">
        <TallyEmbed title="Incorporation quote" />
      </div>
    </div>
  </Section>
</BaseLayout>
