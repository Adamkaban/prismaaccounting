---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ServiceHero from '~/components/service/ServiceHero.astro';
import Deliverables from '~/components/service/Deliverables.astro';
import Pricing from '~/components/service/Pricing.astro';
import ServiceProcess from '~/components/service/ServiceProcess.astro';
import FAQ from '~/components/home/FAQ.astro';
import Section from '~/components/ui/Section.astro';
import TallyEmbed from '~/components/forms/TallyEmbed.astro';
import { SITE } from '~/site.config';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services/' },
  { name: 'HST / GST', href: '/services/hst-gst/' },
];

const deliverables = [
  {
    title: 'CRA registration',
    body: 'Business number and HST/GST account registration with CRA. We select the correct reporting period (monthly, quarterly, or annual) based on your revenue and cash-flow situation.',
  },
  {
    title: 'Return preparation',
    body: 'Periodic HST/GST returns prepared from your records. Sales, input tax credits (ITCs), and net remittance calculated correctly. Late or missed periods caught up.',
  },
  {
    title: 'Input tax credit review',
    body: 'Full review of eligible ITCs you may have missed. Business expenses, capital property, and mixed-use assets all have specific ITC rules we apply on your behalf.',
  },
  {
    title: 'Audit support',
    body: 'CRA HST audits are common for small businesses. We represent you, prepare the working papers, and respond to CRA on your behalf from the initial request through resolution.',
  },
];

const pricingTiers = [
  {
    name: 'Annual filer',
    price: '$249',
    unit: '/ year',
    blurb: 'One HST return per year, standard business income and expenses.',
    features: [
      'Single annual return',
      'ITC calculation',
      'CRA electronic filing',
      'Confirmation number provided',
    ],
  },
  {
    name: 'Quarterly filer',
    price: '$149',
    unit: '/ quarter',
    blurb: 'Four returns per year. Most businesses under $6M revenue.',
    featured: true,
    features: [
      'Four returns per year',
      'ITC review each period',
      'CRA e-filing each quarter',
      'Annual reconciliation included',
    ],
  },
  {
    name: 'Registration + setup',
    price: '$399',
    unit: 'one-time',
    blurb: 'New HST/GST registration with first return and filing period selection.',
    features: [
      'CRA business number registration',
      'Reporting period selection',
      'First return included',
      'Quick method vs regular method review',
    ],
  },
];

const processSteps = [
  {
    n: '01',
    title: 'Intake and period review',
    body: 'We confirm your reporting period, review any missed filings, and request the records needed to prepare each return.',
  },
  {
    n: '02',
    title: 'Returns prepared',
    body: 'Sales and ITCs mapped from your bookkeeping or bank records. Net HST calculated and cross-checked against CRA\'s records where accessible.',
  },
  {
    n: '03',
    title: 'You review the numbers',
    body: 'We send you the completed return with a plain summary of what is owed or refunded and why before filing anything.',
  },
  {
    n: '04',
    title: 'Filed with CRA',
    body: 'Returns submitted electronically. You receive the filing confirmation number and a copy of each completed return for your records.',
  },
];

const faqItems = [
  {
    q: 'Do I have to pay HST if I make less than $30,000?',
    a: 'No - businesses with annual taxable revenue under $30,000 are not required to register for or collect HST; this is the "small supplier" threshold. Once you exceed $30,000 in a single calendar quarter or four consecutive quarters, registration becomes mandatory within 29 days of crossing the line. Voluntarily registering before this threshold lets you claim input tax credits on business expenses.',
  },
  {
    q: 'When do I need to register for HST in Ontario?',
    a: 'You must register once your worldwide taxable supplies exceed $30,000 in a single calendar quarter or over four consecutive quarters. Many small-business owners register voluntarily before hitting the threshold to claim ITCs on startup costs.',
  },
  {
    q: 'What is the Quick Method of accounting for HST?',
    a: 'The Quick Method lets eligible small businesses remit a flat percentage of HST-included revenue to CRA instead of tracking every ITC. It often reduces the net HST owing and simplifies recordkeeping. We review whether it saves you money before recommending it.',
  },
  {
    q: 'My HST account has several missed periods. What happens?',
    a: 'CRA charges interest from the original due date and a late-filing penalty on each missed return. We file all outstanding returns as quickly as possible and request penalty relief through taxpayer relief provisions where the facts support it.',
  },
  {
    q: 'Can I claim HST back on my home-office expenses?',
    a: 'Yes, partially. The ITC is prorated based on the business-use percentage of your home. We calculate the eligible portion and include it in your return.',
  },
  {
    q: 'How long does a CRA HST audit take?',
    a: 'Correspondence audits typically resolve in eight to sixteen weeks. Field audits of small businesses run three to six months. Providing clean, organized records at the start shortens every audit. We assemble the package and handle all CRA communication.',
  },
];
---

<BaseLayout
  title="HST Registration Ontario | Prisma Financial"
  description="HST/GST registration, quarterly and annual returns, input tax credit review, and CRA audit support for Ontario businesses. Fixed CAD pricing."
  path="/services/hst-gst/"
  schemaVariant="service"
  breadcrumbs={breadcrumbs}
  faqItems={faqItems}
  service={{
    name: 'HST / GST Filing',
    description:
      'HST and GST registration, return preparation, input tax credit review, and CRA audit representation for businesses in Toronto and Ontario.',
    serviceType: 'Sales tax preparation',
  }}
>
  <ServiceHero
    eyebrow="HST / GST"
    title="HST Registration and Filing in Ontario"
    subtitle="Registration, quarterly or annual returns, input tax credit review, and CRA audit support. Flat CAD pricing, no surprises."
    breadcrumbs={breadcrumbs}
  />

  <Deliverables
    heading="What we handle for you"
    intro="From your first CRA registration through ongoing filings and any audit that follows."
    items={deliverables}
  />

  <Section divider>
    <div class="grid gap-12 md:grid-cols-12 items-start">
      <div class="md:col-span-5">
        <h2 class="text-4xl md:text-5xl font-medium tracking-tight leading-[1.1] text-balance">
          When do Ontario businesses need to register for HST?
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-[var(--color-ink-muted)] max-w-[52ch]">
          CRA requires registration once your worldwide taxable supplies exceed $30,000 in any single calendar quarter, or in four consecutive quarters. You become a registrant on the day you exceed the threshold - late registration carries interest and penalties from that date.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-[var(--color-ink-muted)] max-w-[52ch]">
          Voluntary registration is often worth it before you hit $30,000. If you have significant startup costs or business expenses with HST, registering early lets you claim input tax credits (ITCs) on those purchases.
        </p>
      </div>
      <div class="md:col-span-6 md:col-start-7">
        <ul class="space-y-4">
          {[
            { label: 'Mandatory threshold', value: '$30,000 / year or quarter' },
            { label: 'Ontario HST rate', value: '13% (5% federal + 8% provincial)' },
            { label: 'Annual filing deadline', value: '3 months after fiscal year-end' },
            { label: 'Quarterly filing deadline', value: '1 month after each quarter' },
            { label: 'Monthly filing deadline', value: '1 month after each period' },
          ].map((row) => (
            <li class="flex items-start justify-between gap-6 border-b border-[var(--color-line)] pb-4">
              <span class="text-[var(--color-ink-muted)] text-sm">{row.label}</span>
              <span class="font-mono font-medium text-sm text-right">{row.value}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Section>

  <Pricing
    heading="Flat CAD pricing"
    intro="Price confirmed before any work begins. No hourly billing, no hidden add-ons."
    tiers={pricingTiers}
    footnote="Prices in CAD plus HST. Catch-up filing for multiple missed periods quoted based on volume. Audit representation quoted separately."
  />

  <ServiceProcess
    heading="How an HST filing works"
    intro="Most returns are prepared and filed within five business days of receiving your records."
    steps={processSteps}
  />

  <FAQ
    id="faq"
    heading="HST and GST questions"
    intro="What Ontario business owners ask us most about sales tax."
    items={faqItems}
  />

  <Section id="quote" bg="elev" divider>
    <div class="grid gap-10 md:grid-cols-12 items-start">
      <div class="md:col-span-5">
        <h2 class="text-4xl md:text-5xl font-medium tracking-tight leading-[1.1] text-balance">
          Get a free quote
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-[var(--color-ink-muted)] max-w-sm">
          Tell us your filing frequency, how many periods are outstanding, and your approximate annual revenue. Price back within one business day.
        </p>
        <p class="mt-6 text-sm text-[var(--color-ink-muted)]">
          Prefer email? Write to <a href={`mailto:${SITE.contact.email}`} class="text-[var(--color-ink)] underline underline-offset-4 hover:text-[var(--color-accent)] transition-colors">{SITE.contact.email}</a>.
        </p>
      </div>
      <div class="md:col-span-7">
        <TallyEmbed title="HST/GST quote" />
      </div>
    </div>
  </Section>
</BaseLayout>
