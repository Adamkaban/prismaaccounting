---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/ui/Section.astro';
import { SITE } from '~/site.config';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Calculators', href: '/tools/' },
];

const tools = [
  {
    title: 'Ontario Salary Calculator 2026',
    description: 'Enter a gross annual salary and see exactly what you take home after federal tax, Ontario tax, CPP, and EI. Monthly and biweekly breakdown included.',
    href: '/tools/ontario-salary-calculator/',
    badge: 'Free',
    detail: 'Net pay after all deductions',
  },
  {
    title: 'Salary vs Dividend Calculator 2026',
    description: 'If you own an Ontario corporation, this compares the real after-tax cost of paying yourself salary versus dividends from corporate profit. Uses 2026 small business deduction rates.',
    href: '/tools/salary-vs-dividend/',
    badge: 'Free',
    detail: 'For incorporated owners',
  },
];
---

<BaseLayout
  title="Free Ontario Tax Calculators 2026 | Prisma Financial"
  description="Two free calculators for Canadian tax: see your Ontario net salary after tax and CPP/EI, or compare salary vs dividends for your incorporated business. 2026 CRA rates."
  path="/tools/"
  schemaVariant="page"
  breadcrumbs={breadcrumbs}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Free Ontario Tax Calculators 2026',
    description: 'Free tax calculators for Ontario residents and incorporated business owners. Net salary calculator and salary vs dividends calculator using 2026 CRA rates.',
    url: `${SITE.url}/tools/`,
    publisher: { '@id': `${SITE.url}/#organization` },
    hasPart: [
      {
        '@type': 'WebApplication',
        name: 'Ontario Salary Calculator 2026',
        url: `${SITE.url}/tools/ontario-salary-calculator/`,
        applicationCategory: 'FinanceApplication',
        offers: { '@type': 'Offer', price: '0', priceCurrency: 'CAD' },
      },
      {
        '@type': 'WebApplication',
        name: 'Salary vs Dividend Calculator Ontario 2026',
        url: `${SITE.url}/tools/salary-vs-dividend/`,
        applicationCategory: 'FinanceApplication',
        offers: { '@type': 'Offer', price: '0', priceCurrency: 'CAD' },
      },
    ],
  })} />

  <Section id="hero">
    <nav aria-label="Breadcrumb" class="mb-8 text-sm text-[var(--color-ink-muted)]">
      <ol class="flex items-center gap-2">
        {breadcrumbs.map((crumb, i) => (
          <li class="flex items-center gap-2">
            {i > 0 && <span aria-hidden="true">/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={crumb.href} class="hover:text-[var(--color-ink)] transition-colors">{crumb.name}</a>
              : <span class="text-[var(--color-ink)]">{crumb.name}</span>
            }
          </li>
        ))}
      </ol>
    </nav>
    <h1 class="text-5xl md:text-7xl font-medium tracking-tight leading-[1.05] text-balance max-w-3xl">
      Free Canadian Tax Calculators
    </h1>
    <p class="mt-6 text-lg leading-relaxed text-[var(--color-ink-muted)] max-w-[58ch]">
      Two free tools built for Ontario residents and small business owners. All calculations use 2026 CRA federal and Ontario tax rates.
    </p>
  </Section>

  <Section id="tools" divider>
    <div class="grid gap-6 md:grid-cols-2 max-w-4xl">
      {tools.map((tool) => (
        <a
          href={tool.href}
          class="group rounded-2xl border bg-[var(--color-bg-elev)] p-8 hover:border-[var(--color-accent)] transition-[border-color] duration-200"
          style="border-color: var(--color-line)"
        >
          <div class="flex items-start justify-between gap-4 mb-4">
            <span class="text-xs font-medium px-3 py-1 rounded-full" style="background: color-mix(in srgb, var(--color-accent) 10%, var(--color-bg)); color: var(--color-accent)">
              {tool.badge}
            </span>
            <span class="text-xs text-[var(--color-ink-muted)]">{tool.detail}</span>
          </div>
          <h2 class="text-xl font-medium leading-snug group-hover:text-[var(--color-accent)] transition-colors">
            {tool.title}
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-[var(--color-ink-muted)]">
            {tool.description}
          </p>
          <p class="mt-6 text-sm font-medium text-[var(--color-accent)]">
            Use calculator &rarr;
          </p>
        </a>
      ))}
    </div>
  </Section>

  <Section id="cta" divider>
    <p class="text-lg leading-relaxed text-[var(--color-ink-muted)] max-w-[60ch]">
      These calculators show directional numbers. For your specific situation - with RRSP contributions, other income, or a complex corporate structure - talk to a CPA. We quote a flat CAD price before any work starts.
    </p>
    <a
      href="/#quote"
      class="mt-6 inline-flex items-center px-6 py-3 rounded-full font-medium text-sm transition-colors"
      style="background: var(--color-accent); color: var(--color-bg-elev)"
      onmouseover="this.style.background='var(--color-accent-hi)'"
      onmouseout="this.style.background='var(--color-accent)'"
    >
      Get a free quote
    </a>
  </Section>
</BaseLayout>
