---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/home/Hero.astro';
import Trust from '~/components/home/Trust.astro';
import ServicesGrid from '~/components/home/ServicesGrid.astro';
import Process from '~/components/home/Process.astro';
import FAQ from '~/components/home/FAQ.astro';
import Section from '~/components/ui/Section.astro';
import TallyEmbed from '~/components/forms/TallyEmbed.astro';
import { SITE } from '~/site.config';
---

<BaseLayout
  title="Toronto Accountant | Tax & Bookkeeping"
  description="Certified accountants in Toronto for personal tax (T1), corporate tax (T2), HST/GST, payroll, bookkeeping, and incorporation. Fixed CAD pricing, CRA-ready filing."
  path="/"
  schemaVariant="home"
>
  <Hero />
  <Trust />
  <ServicesGrid />
  <Process />
  <FAQ />

  <Section id="quote" bg="elev" divider>
    <div class="grid gap-10 md:grid-cols-12 items-start">
      <div class="md:col-span-5">
        <h2 class="text-4xl md:text-5xl font-medium tracking-tight leading-[1.1] text-balance">
          Get a free quote
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-[var(--color-ink-muted)] max-w-sm">
          Tell us a bit about your situation. We respond within one business day with a fixed CAD price and the documents we need.
        </p>
        <p class="mt-6 text-sm text-[var(--color-ink-muted)]">
          Prefer email? Write to <a href={`mailto:${SITE.contact.email}`} class="text-[var(--color-ink)] underline underline-offset-4 hover:text-[var(--color-accent)] transition-colors">{SITE.contact.email}</a>.
        </p>
      </div>
      <div class="md:col-span-7">
        <TallyEmbed />
      </div>
    </div>
  </Section>
</BaseLayout>
